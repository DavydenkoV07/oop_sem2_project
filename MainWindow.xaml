<Window x:Class="HobbyTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hobby Tracker" Height="500" Width="850" WindowStartupLocation="CenterScreen" Background="#f8f9fa" FontFamily="Segoe UI">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛІВА ПАНЕЛЬ: Категорії (Сайдбар) -->
        <Border Grid.Column="0" Background="#ffffff" BorderBrush="#e9ecef" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Мої хобі" FontSize="22" FontWeight="Bold" Foreground="#212529" Margin="15,20,15,15"/>
                
                <ListBox x:Name="CategoriesListBox" Grid.Row="1" Margin="10,0" BorderThickness="0" Background="Transparent"
                         DisplayMemberPath="Name" SelectionChanged="CategoriesListBox_SelectionChanged" FontSize="15"/>
                
                <StackPanel Grid.Row="2" Margin="15,20">
                    <TextBox x:Name="NewCategoryTextBox" Text="Нова категорія..."/>
                    <Button Content="Додати розділ" Style="{StaticResource PrimaryButtonStyle}" Click="AddCategory_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ПРАВА ПАНЕЛЬ: Вміст обраної категорії -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="SelectedCategoryTextBlock" Text="Оберіть розділ ліворуч" 
                       FontSize="26" FontWeight="Bold" Foreground="#212529" Grid.Row="0" Margin="0,0,0,15"/>

            <StackPanel x:Name="AddItemPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15" IsEnabled="False">
                <Button Content="+ Додати новий запис" Style="{StaticResource PrimaryButtonStyle}" Click="AddItem_Click"/>
            </StackPanel>

            <DataGrid x:Name="ItemsDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                      RowHeight="40" Background="White" BorderBrush="#dee2e6" BorderThickness="1" HeadersVisibility="Column"
                      MouseDoubleClick="ItemsDataGrid_MouseDoubleClick" FontSize="14">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Рік" Binding="{Binding ReleaseYear}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>