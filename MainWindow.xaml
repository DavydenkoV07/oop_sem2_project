<Window x:Class="HobbyTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hobby Tracker" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    
    <Grid>
        <!-- Ділимо вікно на дві колонки: 200 пікселів для сайдбару, решта (*) для контенту -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛІВА ПАНЕЛЬ: Категорії -->
        <Grid Grid.Column="0" Background="#F4F4F4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Мої хобі" FontSize="18" FontWeight="Bold" Margin="10"/>
            
            <!-- Список категорій -->
            <ListBox x:Name="CategoriesListBox" Grid.Row="1" Margin="10,0" 
                     DisplayMemberPath="Name" SelectionChanged="CategoriesListBox_SelectionChanged"/>
            
            <!-- Форма додавання категорії -->
            <StackPanel Grid.Row="2" Margin="10">
                <TextBox x:Name="NewCategoryTextBox" Padding="5" Margin="0,0,0,5" />
                <Button Content="Додати розділ" Padding="5" Click="AddCategory_Click"/>
            </StackPanel>
        </Grid>

        <!-- ПРАВА ПАНЕЛЬ: Вміст обраної категорії -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="SelectedCategoryTextBlock" Text="Оберіть розділ ліворуч" 
                       FontSize="20" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,10"/>

            <!-- Форма додавання нового елемента -->
            <StackPanel x:Name="AddItemPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" IsEnabled="False">
                <TextBox x:Name="NewItemTitleTextBox" Width="200" Padding="5" Margin="0,0,10,0" />
                <Button Content="Додати запис" Width="120" Padding="5" Click="AddItem_Click"/>
            </StackPanel>

            <!-- Таблиця елементів -->
            <DataGrid x:Name="ItemsDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Назва" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Рік" Binding="{Binding ReleaseYear}" Width="80"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>