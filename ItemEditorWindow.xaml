<Window x:Class="HobbyTracker.ItemEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Деталі запису" Height="600" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#f8f9fa" FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Назва:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" />

        <TextBlock Text="Рік випуску:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="YearTextBox" Grid.Row="1" Grid.Column="1" />

        <TextBlock Text="Статус:" Grid.Row="2" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Padding="5" FontSize="14"/>

        <TextBlock Text="Посилання:" Grid.Row="3" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="LinkTextBox" Grid.Row="3" Grid.Column="1" />

        <TextBlock Text="Опис:" Grid.Row="4" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Top" FontWeight="SemiBold" Padding="0,8,0,0"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="4" Grid.Column="1" Height="70" TextWrapping="Wrap" AcceptsReturn="True" />

        <TextBlock Text="Мій коментар:" Grid.Row="5" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Top" FontWeight="SemiBold" Padding="0,8,0,0"/>
        <TextBox x:Name="CommentTextBox" Grid.Row="5" Grid.Column="1" Height="70" TextWrapping="Wrap" AcceptsReturn="True" />

        <!-- Кнопки -->
        <Grid Grid.Row="7" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="DeleteButton" Content="Видалити" Grid.Column="0" Style="{StaticResource DangerButtonStyle}" Click="Delete_Click"/>
            
            <Button Content="Скасувати" Grid.Column="2" Padding="12,8" Margin="0,0,10,0" Background="#6c757d" Foreground="White" BorderThickness="0" Click="Cancel_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <Button Content="Зберегти" Grid.Column="3" Style="{StaticResource PrimaryButtonStyle}" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>