<Window x:Class="HobbyTracker.ItemEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редагування запису" Height="400" Width="350" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Назва -->
        <TextBlock Text="Назва:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="3"/>

        <!-- Рік -->
        <TextBlock Text="Рік випуску:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox x:Name="YearTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="3"/>

        <!-- Статус -->
        <TextBlock Text="Статус:" Grid.Row="2" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <ComboBox x:Name="StatusComboBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Padding="3"/>

        <!-- Посилання -->
        <TextBlock Text="Посилання:" Grid.Row="3" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox x:Name="LinkTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Padding="3"/>

        <!-- Опис -->
        <TextBlock Text="Опис:" Grid.Row="4" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Top"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="4" Grid.Column="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" Padding="3"/>

        <!-- Коментар -->
        <TextBlock Text="Мій коментар:" Grid.Row="5" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Top"/>
        <TextBox x:Name="CommentTextBox" Grid.Row="5" Grid.Column="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" Padding="3"/>

        <!-- Кнопки керування -->
        <Grid Grid.Row="7" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="DeleteButton" Content="Видалити" Grid.Column="0" Width="80" Padding="5" Foreground="Red" Click="Delete_Click"/>
            <Button Content="Скасувати" Grid.Column="2" Width="80" Padding="5" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Зберегти" Grid.Column="3" Width="80" Padding="5" FontWeight="Bold" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>